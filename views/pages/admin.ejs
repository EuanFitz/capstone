<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../partials/head') %>
</head>
<body>
    <header>
        
    </header>
    <main>
        <section>
            <h2>Admin Registration</h2>
                <form>
                    <div>
                        <label for="name">Full Name*</label>
                        <input type="text" name="name" id="name" placeholder="Full Name" required>
                    </div>
                    <div>
                    <div>
                        <label for="email">Work Email*</label>
                        <input type="email" name="email" id="email" placeholder="Email" required>
                    </div>
                    <div>
                        <label for="phone">Work Phone(If Applicable)</label>
                        <input type="tel" name="phone" id="phone" placeholder="Phone">
                    </div>
                    <button type="submit" name="submit">Submit Registration</button>
                </form>
        </section>
        <section>
            <img src="/LogoBlue.svg" alt="ClickSafe logo">
            <h2>Welcome to ClickSafe</h2>
            <p>Register your business, allow employees to be added to your network, then you’ll be able to start a campaign from your admin dashboard. </p>

            <p>Thank you for using ClickSafe!</p>
        </section>
    </main>
</body>
</html>