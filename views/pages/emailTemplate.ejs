<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../includes/head') %>
    <link rel="stylesheet" href="/css/emailTemplate.css">
</head>
<body class="sideNavPage">
  <%- include('../includes/sideNav') %>
  <main>
    <h1><%= title %></h1>
<!----------------Boxes above RightSide templates------------>
    <div class="sideTemplates">

      <div id="methodContainer">
        <span>Method</span>
        <label for="checkEmail">Email</label>
        <input type="checkbox" checked>

        <label for="checkText">Text</label>
        <input type="checkbox">

        <label for="checkPhone">Phone</label>
        <input type="checkbox">
      </div>
<!------Mini Templates -->
      <section class="miniTemplates">

        <div class="templateCard active"
          data-content="Dear Employee,\n\nPlease verify your account credentials immediately by clicking the link below. Failure to do so will result in account suspension.">
          <p class="templateCardName">IT Email</p>
          <div class="templatePreview">
            <div class="previewSubject">Confirm Credentials</div>
            <div class="previewLines">
              <div class="previewLine"></div>
              <div class="previewLine short"></div>
              <div class="previewLine"></div>
              <div class="previewLine short"></div>
            </div>
          </div>
        </div>

        <div class="templateCard"
          data-content="Urgent: Your invoice #4821 is ready.\n\nPlease download and review the attached invoice immediately. If you have questions, contact billing.\n">
          <p class="templateCardName">Payroll Email</p>
          <div class="templatePreview">
            <div class="previewSubject">Urgent Invoice</div>
            <div class="previewLines">
              <div class="previewLine"></div>
              <div class="previewLine short"></div>
              <div class="previewLine"></div>
              <div class="previewLine short"></div>
            </div>
          </div>
        </div>

        <div class="templateCard"
          data-content="Hi there,\n\nYou have a pending document awaiting your signature. Please sign immediately to avoid delays.">
          <p class="templateCardName">Legal Email</p>
          <div class="templatePreview">
            <div class="previewSubject">Pending Document</div>
            <div class="previewLines">
              <div class="previewLine"></div>
              <div class="previewLine short"></div>
              <div class="previewLine"></div>
              <div class="previewLine short"></div>
            </div>
          </div>
        </div>

      </section>


    </div>




<!-----------------------Fake Email Form----------------------->
    <section class="emailContainer">
      <form action="">

        <input type="text" id="templateName" placeholder="Template Name" class="templateNameInput">        
<!-------TO:   -->
       <div class="emailField emailField-to">
        <label for="emailTo">To:</label>
        <button class="emailButton" type="button">+</button>
        <div id="recipientTags"></div>

        

        <select name="emailTo" id="emailTo">
            <option value="">Human Resources</option>
            <option value="">Marketing</option>
            <option value="">Sales</option>
        </select>
      </div>

<!-------FROM:   -->
      <div class="emailField emailField-from">
          <label for="emailFrom">From:</label>
          <button class="emailButton" type="button">▶</button>
          <span id="fromValue">Select sender...</span>

          

          <select name="emailFrom" id="emailFrom">
              <option value="">Manager</option>
              <option value="">Area Manager</option>
              <option value="">CFO</option>
              <option value="">Human Resources</option>
          </select>
      </div>

<!-------body   -->
    <textarea id="emailBody" placeholder="Write your phishing email content here, or select a template from the right to pre-fill..."></textarea>

<!-- Phishing link field -->
  <div class="emailField linkField">
      <span class="fieldLabel">Link Text:</span>
      <input 
          type="text" 
          id="linkDisplayText" 
          placeholder="www.Write_A_Fake_link_here.com"
          class="linkTextInput"
      />
      <span class="linkPreview">
          → will display as: 
          <a id="linkPreview" href="/oops" target="_blank">Click here to verify your account</a>
      </span>
  </div>

<!-------Signature area stuff   -->
    <pre id="emailSignature" class="emailSignature"></pre>

<!-------save or trash  -->  
       <div class="saveArchive">

        <!-- <button id="save"><svg width="38" height="39" viewBox="0 0 38 39" fill="none" xmlns="http://www.w3.org/2000/svg">
<path d="M29 37.75V21.4167H8.99995V37.75M8.99995 1V11.2083H25M33 37.75H5C3.93913 37.75 2.92172 37.3198 2.17157 36.554C1.42143 35.7882 1 34.7496 1 33.6667V5.08333C1 4.00037 1.42143 2.96175 2.17157 2.19598C2.92172 1.43021 3.93913 1 5 1H27L37 11.2083V33.6667C37 34.7496 36.5786 35.7882 35.8284 36.554C35.0783 37.3198 34.0609 37.75 33 37.75Z" stroke="#6750A4" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
</svg></button> -->

        <button id="delete"><svg width="42" height="44" viewBox="0 0 42 44" fill="none" xmlns="http://www.w3.org/2000/svg">
<path d="M27.6434 15.2388L26.8041 34.2239M15.1958 34.2239L14.3567 15.2388M38.5215 8.46867C39.3505 8.57761 40.1767 8.69417 41 8.81825M38.5215 8.46867L35.9328 37.7522C35.7142 40.2249 33.3445 42.1344 30.4943 42.1344H11.5056C8.65542 42.1344 6.28575 40.2249 6.06715 37.7522L3.47842 8.46867M38.5215 8.46867C35.7423 8.10346 32.9309 7.82377 30.0909 7.6328M3.47842 8.46867C2.64938 8.57761 1.8232 8.69417 1 8.81825M3.47842 8.46867C6.25765 8.10346 9.06907 7.82377 11.9091 7.6328M30.0909 7.6328V5.70027C30.0909 3.21244 27.8832 1.13549 25.0257 1.05594C23.689 1.01875 22.3469 1 21 1C19.6531 1 18.311 1.01875 16.9743 1.05594C14.1167 1.13549 11.9091 3.21244 11.9091 5.70027V7.6328M30.0909 7.6328C27.0912 7.4311 24.0594 7.32837 21 7.32837C17.9406 7.32837 14.9089 7.4311 11.9091 7.6328" stroke="#6750A4" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
</svg></button>

       </div>
      </form>
    </section>
<!-------------------Launch Campaign----------------->
    <div class="launchContainer">
      <button id="launchButton">Save Template</button>
    </div>
<!---------------------Option Buttons---------------->

  <div class="optionsContainer">
    <button class="optionBttn">Option 1</button>
    <button class="optionBttn">Option 2</button>
    <button class="optionBttn">Option 3</button>
    
  </div>




    </main>

    <%- include('../includes/footer') %>

    <script src="/js/emailTemplate.js"></script>
</body>
</html>